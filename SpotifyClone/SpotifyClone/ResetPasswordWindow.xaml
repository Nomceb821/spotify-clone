<Window x:Class="SpotifyClone.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpotifyClone"
        mc:Ignorable="d"
        Title="ResetPasswordWindow" Height="500" Width="450"
        Background="#121212"
        WindowStartupLocation="CenterScreen">
    <Grid>

        <!-- MAIN CARD -->
        <Border Width="350"
                Height="420"
                Background="#181818"
                CornerRadius="25"
                Padding="30"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Reset Password"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- EMAIL -->
                <TextBlock Text="Email"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <Border CornerRadius="22"
                        BorderBrush="#535353"
                        BorderThickness="1"
                        Background="#2A2A2A"
                        Margin="0,0,0,20">

                    <TextBox x:Name="EmailTextBox"
                             Height="45"
                             Padding="15,10"
                             Background="Transparent"
                             Foreground="White"
                             CaretBrush="White"
                             BorderThickness="0"
                             FontSize="15"
                             VerticalContentAlignment="Center"/>

                </Border>

                <!-- NEW PASSWORD -->
                <TextBlock Text="New Password"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,5"/>

                <Border CornerRadius="22"
                        BorderBrush="#535353"
                        BorderThickness="1"
                        Background="#2A2A2A"
                        Margin="0,0,0,30">

                    <Grid>

                        <!-- PASSWORD BOX -->
                        <PasswordBox x:Name="NewPasswordTextBox"
                                     Height="45"
                                     Padding="15,10"
                                     Background="Transparent"
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="15"/>

                        <!-- VISIBLE PASSWORD -->
                        <TextBox x:Name="VisibleNewPasswordTextBox"
                                 Height="45"
                                 Padding="15,10"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="15"
                                 Visibility="Collapsed"/>

                        <!-- EYE BUTTON -->
                        <Button Content="👁"
                                Width="40"
                                Height="40"
                                HorizontalAlignment="Right"
                                Margin="0,2,2,0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="White"
                                Cursor="Hand"
                                Click="ShowPasswordButton_Click"/>

                    </Grid>

                </Border>

                <!-- RESET BUTTON -->
                <Button Content="RESET PASSWORD"
                        Height="50"
                        Background="#1DB954"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        BorderThickness="0"
                        Click="ResetPasswordButton_Click">

                    <Button.Template>

                        <ControlTemplate TargetType="Button">

                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="25">

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>

                            </Border>

                        </ControlTemplate>

                    </Button.Template>

                </Button>

            </StackPanel>

        </Border>

    </Grid>
</Window>
