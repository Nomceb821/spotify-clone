<Window x:Class="SpotifyClone.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpotifyClone"
        mc:Ignorable="d"
        Title="AuthWindow" Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        >
    <Grid>

        <Border Width="380"
                Height="580"
                Background="#181818"
                CornerRadius="20"
                Padding="30"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <StackPanel>

                <!-- LOGO -->
                <TextBlock Text="Spotify"
                           Foreground="White"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- TITLE -->
                <TextBlock Text="Log in to continue"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- EMAIL -->
                <TextBlock Text="Email"
                           Foreground="White"
                           Margin="0,0,0,5"/>

                <Border CornerRadius="25"
                    BorderBrush="#535353"
                    BorderThickness="1"
                    Background="#2A2A2A"
                    Margin="0,0,0,20">

                    <TextBox x:Name="EmailTextBox"
                         Height="45"
                         FontSize="16"
                         Padding="10"
                         Background="Transparent"
                         Foreground="White"
                         BorderThickness="0"
                         CaretBrush="White"
                         VerticalContentAlignment="Center"/>

                </Border>

                <!-- PASSWORD -->
                <TextBlock Text="Password"
                   Foreground="White"
                   Margin="0,0,0,5"/>

                <Border CornerRadius="25"
                    BorderBrush="#535353"
                    BorderThickness="1"
                    Background="#2A2A2A"
                    Margin="0,0,0,30">

                    <Grid>

                        <!-- PASSWORD BOX -->
                        <PasswordBox x:Name="PasswordTextBox"
                             Height="45"
                             FontSize="16"
                             Padding="10"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"/>

                        <!-- VISIBLE PASSWORD -->
                        <TextBox x:Name="VisiblePasswordTextBox"
                             Height="45"
                             FontSize="16"
                             Padding="10"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"/>

                        <!-- EYE BUTTON -->
                        <Button Content="👁"
                            Width="40"
                            Height="40"
                            HorizontalAlignment="Right"
                            Margin="0,2,2,0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="White"
                            Cursor="Hand"
                            Click="ShowPasswordButton_Click"/>

                    </Grid>

                </Border>

                <!-- LOGIN BUTTON -->
                <Button Content="LOG IN"
                    Height="50"
                    Background="#1DB954"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="16"
                    Cursor="Hand"
                    BorderThickness="0"
                    Click="LoginButton_Click">  <!-- When click it is connected to MainWindow.cs where there is playerWindow -->

                    <Button.Template>

                        <ControlTemplate TargetType="Button">

                            <Border Background="{TemplateBinding Background}"
                                CornerRadius="25">

                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                            </Border>

                        </ControlTemplate>

                    </Button.Template>

                </Button>

                <!-- SIGN UP -->
                <TextBlock Text="Don't have an account?"
                           Foreground="#B3B3B3"
                           Margin="0,30,0,10"
                           HorizontalAlignment="Center"/>

                <Button Content="SIGN UP"
                    Height="45"
                    Background="Transparent"
                    Foreground="White"
                    BorderBrush="White"
                    BorderThickness="1"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Cursor="Hand">

                    <Button.Template>

                        <ControlTemplate TargetType="Button">

                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22">

                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                            </Border>

                        </ControlTemplate>

                    </Button.Template>

                </Button>

            </StackPanel>

        </Border>

    </Grid>
</Window>
