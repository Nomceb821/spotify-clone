<Window x:Class="SpotifyClone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpotifyClone"
        mc:Ignorable="d"
        Title="Spotify Clone"
        Height="700"
        Width="1200"
        Background="#F2F2F2">

    <Window.Resources>

        <!-- MODERN BUTTON STYLE -->
        <Style TargetType="Button">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="25">

                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>

                        </Border>

                        <!-- HOVER EFFECT -->
                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                 Value="True">

                                <Setter TargetName="border"
                                    Property="Opacity"
                                    Value="0.85"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel>

            <!-- HERO SECTION -->
            <Grid Height="500">

                <!-- GRADIENT BACKGROUND -->
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E0B3A" Offset="0"/>
                        <GradientStop Color="#4A0D29" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- NAVBAR -->
                <Grid Height="80"
                      VerticalAlignment="Top">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- SPOTIFY LOGO -->
                    <TextBlock Text="Spotify"
                               Foreground="White"
                               FontSize="32"
                               FontWeight="Bold"
                               Margin="40,20"/>

                    <!-- MENU -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Margin="0,20,40,0">

                        <Button Content="Download"
                                Margin="10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="Transparent"/>

                        <Button Content="Premium"
                                Margin="10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="Transparent"/>

                        <Button Content="Help"
                                Margin="10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="Transparent"/>

                        <Button Content="Log In"
                                Margin="10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="Transparent"
                                Click="LoginNavButton_Click"/>
                    </StackPanel>

                </Grid>

                <!-- HERO CONTENT -->
                <Grid Margin="100,140,100,60">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDE -->
                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="MUSIC FOR"
                                   Foreground="White"
                                   FontSize="60"
                                   FontWeight="Bold"/>

                        <TextBlock Text="EVERYONE."
                                   Foreground="White"
                                   FontSize="60"
                                   FontWeight="Bold"/>

                        <TextBlock Text="Millions of songs. No credit card needed."
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="0,20,0,30"/>

                        <Button Content="GET SPOTIFY FREE"
                                Click="GetSpotifyButton_Click"
                                Width="250"
                                Height="50"
                                Background="#1DB954"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderBrush="Transparent"
                                FontSize="16"
                                Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5">

                            <!-- GLOW EFFECT -->
                            <Button.Effect>

                                <DropShadowEffect Color="#1DB954"
                                      BlurRadius="25"
                                      ShadowDepth="0"
                                      Opacity="0.8"/>

                            </Button.Effect>

                            <!-- SCALE EFFECT -->
                            <Button.RenderTransform>
                                <ScaleTransform/>
                            </Button.RenderTransform>

                            <!-- PULSE ANIMATION -->
                            <Button.Triggers>

                                <EventTrigger RoutedEvent="Button.Loaded">

                                    <BeginStoryboard>

                                        <Storyboard RepeatBehavior="Forever"
                                            AutoReverse="True">

                                            <DoubleAnimation
                                                Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                From="1"
                                                To="1.08"
                                                Duration="0:0:0.7"/>

                                            <DoubleAnimation
                                                Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                From="1"
                                                To="1.08"
                                                Duration="0:0:0.7"/>    

                                        </Storyboard>

                                    </BeginStoryboard>

                                </EventTrigger>

                            </Button.Triggers>

                        </Button>

                    </StackPanel>

                    <!-- RIGHT SIDE -->
                    <Grid Grid.Column="1">

                        <!-- BIG IMAGE CARD -->
                        <Border Width="350"
                                Height="350"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                CornerRadius="20"
                                ClipToBounds="True">

                            <Image Source="/Assets/Images/album1.jpeg"
                                   Stretch="Fill"/>

                        </Border>

                        <!-- SMALL IMAGE CARD -->
                        <Border Width="300"
                                Height="250"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,50,0"
                                CornerRadius="20"
                                ClipToBounds="True">

                            <Image Source="/Assets/Images/hozier.jpg"
                                   Stretch="Fill"/>

                        </Border>

                    </Grid>

                </Grid>

            </Grid>

            <!-- SECOND SECTION -->
            <StackPanel Margin="80,40">

                <TextBlock Text="SPOTIFY HAS ALL THAT YOU NEED."
                           FontSize="40"
                           FontWeight="Bold"
                           Margin="0,0,0,30"/>

                <!-- IMAGE CARDS -->
                <WrapPanel>



                    <!-- CARD 1 -->
                    <Border Width="305"
                            Height="300"
                            Margin="15"
                            CornerRadius="20"
                            ClipToBounds="True"
                            RenderTransformOrigin="0.5,0.5">

                        <Border.RenderTransform>
                            <ScaleTransform/>
                        </Border.RenderTransform>

                        <Border.Effect>

                            <DropShadowEffect BlurRadius="20"
                          ShadowDepth="5"
                          Opacity="0.3"/>

                        </Border.Effect>

                        <Border.Triggers>

                            <EventTrigger RoutedEvent="MouseEnter">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1.03"
                                            Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                        To="1.03"
                                        Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                To="1"
                                            Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                        </Border.Triggers>

                        <Image Source="/Assets/Images/Album2.png"
                            Stretch="Fill"
                               Cursor="Hand"/>

                    </Border>

                    <!-- CARD 2 -->
                    <Border Width="305"
                            Height="300"
                            Margin="15"
                            CornerRadius="20"
                            ClipToBounds="True"
                            RenderTransformOrigin="0.5,0.5">

                        <Border.RenderTransform>
                            <ScaleTransform/>
                        </Border.RenderTransform>

                        <Border.Effect>

                            <DropShadowEffect BlurRadius="20"
                          ShadowDepth="5"
                          Opacity="0.3"/>

                        </Border.Effect>

                        <Border.Triggers>

                            <EventTrigger RoutedEvent="MouseEnter">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1.03"
                                            Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                        To="1.03"
                                        Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                To="1"
                                            Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                        </Border.Triggers>

                        <Image Source="/Assets/Images/AmandaBlack.jpg"
                            Stretch="Fill"
                               Cursor="Hand"/>

                    </Border>

                    <!-- CARD 3 -->
                    <Border Width="305"
                            Height="300"
                            Margin="15"
                            CornerRadius="20"
                            ClipToBounds="True"
                            RenderTransformOrigin="0.5,0.5">

                        <Border.RenderTransform>
                            <ScaleTransform/>
                        </Border.RenderTransform>

                        <Border.Effect>

                            <DropShadowEffect BlurRadius="20"
                          ShadowDepth="5"
                          Opacity="0.3"/>

                        </Border.Effect>

                        <Border.Triggers>

                            <EventTrigger RoutedEvent="MouseEnter">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1.03"
                                            Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                        To="1.03"
                                        Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                To="1"
                                            Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                        </Border.Triggers>

                        <Image Source="/Assets/Images/Menzi.jpg"
                            Stretch="Fill"
                               Cursor="Hand"/>

                    </Border>
                    <!-- CARD 4 -->
                    <Border Width="305"
                            Height="300"
                            Margin="15"
                            CornerRadius="20"
                            ClipToBounds="True"
                            RenderTransformOrigin="0.5,0.5">

                        <Border.RenderTransform>
                            <ScaleTransform/>
                        </Border.RenderTransform>

                        <Border.Effect>

                            <DropShadowEffect BlurRadius="20"
                          ShadowDepth="5"
                          Opacity="0.3"/>

                        </Border.Effect>

                        <Border.Triggers>

                            <EventTrigger RoutedEvent="MouseEnter">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1.03"
                                            Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                        Storyboard.TargetProperty="RenderTransform.ScaleY"
                                        To="1.03"
                                        Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                            <EventTrigger RoutedEvent="MouseLeave">

                                <BeginStoryboard>

                                    <Storyboard>

                                        <DoubleAnimation
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             To="1"
                                             Duration="0:0:0.2"/>

                                        <DoubleAnimation
                                             Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                To="1"
                                            Duration="0:0:0.2"/>

                                    </Storyboard>

                                </BeginStoryboard>

                            </EventTrigger>

                        </Border.Triggers>

                        <Image Source="/Assets/Images/TaylorSwift.png"
                            Stretch="Fill"
                            Cursor="Hand"/>

                    </Border>

                </WrapPanel>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</Window>